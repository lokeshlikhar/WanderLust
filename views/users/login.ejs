<% layout('layouts/boilerplate') -%>

<div class="form-page auth-page">
  <h1>Login</h1>
  <form action="/login" method="post" class="needs-validation" novalidate>
    <div class="mb-3">
      <label for="username" class="form-label">Username</label>
      <input name="username" id="username" class="form-control" type="text" required></input>


    </div>

    <div class="mb-3">
      <label for="password" class="form-label">Password</label>
      <input name="password" id="password" class="form-control" type="password" required></input>


    </div>
    <button class="btn add-btn">Login</button>
  </form>
  <div class="mt-4">
    <a href="/signup" class="btn btn-outline-secondary">Don't have an Account</a>
  </div>

</div>