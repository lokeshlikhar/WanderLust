<% layout('layouts/boilerplate') -%>

<main class="form-page" style="max-width: 900px">
  <div class="text-center mb-5">
    <i class="fa-regular fa-compass" aria-hidden="true"></i>
    <h1 class="mt-3">Welcome to WanderLust</h1>
    <p class="lead text-secondary mb-0">
      Find memorable stays, share your home, and travel with confidence.
    </p>
  </div>

  <div class="row g-4">
    <section class="col-md-6">
      <h3><i class="fa-solid fa-heart me-2"></i>For guests</h3>
      <p class="text-secondary">
        Browse unique homes, compare destinations, read honest guest reviews,
        and use the map to discover where each stay is located.
      </p>
      <a href="/listings" class="btn add-btn">Explore listings</a>
    </section>

    <section class="col-md-6">
      <h3><i class="fa-solid fa-house me-2"></i>For hosts</h3>
      <p class="text-secondary">
        Create a listing with photos, location details, pricing, and up to four
        categories so travellers can find the right place.
      </p>
      <a href="/listings/new" class="btn add-btn">List your home</a>
    </section>

    <section class="col-12 border-top pt-4 mt-4">
      <h3>Our commitment</h3>
      <p class="text-secondary mb-0">
        WanderLust is built to make discovering stays simple and welcoming.
        Accounts are required for creating listings and reviews, helping keep
        the community thoughtful and accountable.
      </p>
    </section>
  </div>
</main>
