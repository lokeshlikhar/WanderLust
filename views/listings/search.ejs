<% layout('layouts/boilerplate') -%>

<body>
  <%# <h1>All Listings</h1> %>
  <!-- <form action="/listings/new" method="get">
        <button>Create new Listing</button>
    </form> -->

  <%# div for filter %>
  <div id="filters">
    <a href="/listings/category/Beach" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-water-ladder"></i></div>
        <p>Beach</p>
      </div>
    </a>
    <a href="/listings/category/Mountain" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountain</p>
      </div>
    </a>
    <a href="/listings/category/Camping" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Camping</p>
      </div>
    </a>
    <a href="/listings/category/Luxury" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-crown"></i></div>
        <p>Luxury</p>
      </div>
    </a>
    <a href="/listings/category/Budget" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-house"></i></div>
        <p>Budget</p>
      </div>
    </a>
    <a href="/listings/category/Nature" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Nature</p>
      </div>
    </a>

    <a href="/listings/category/City" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-city"></i></div>
        <p>City</p>
      </div>
    </a>
    <a href="/listings/category/Lake" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-water"></i></div>
        <p>Lake</p>
      </div>
    </a>
    <a href="/listings/category/Historical" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-archway"></i></div>
        <p>Historical</p>
      </div>
    </a>
    <a href="/listings/category/Adventure" class="filter-link">
      <div class="filter">
        <div><i class="fa-regular fa-compass filtercompass"></i></div>
        <p>Adventure</p>
      </div>
    </a>
    <a href="/listings/category/Island" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-earth-americas"></i></div>
        <p>Island</p>
      </div>
    </a>
    <a href="/listings/category/Farm Stay" class="filter-link">
      <div class="filter">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farm Stay</p>
      </div>
    </a>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
        <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
      </div>
    </div>
  </div>

  <div>
    <h3 class="mb-4">
      Search Results for <%= destination %>
    </h3>

  </div>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-1">
    <% if (listings.length === 0) { %>
    <div class="alert alert-warning">
      No listings found.
    </div>
    <% } %>


    <% for(let listing of listings){ %>

    <a href="/listings/<%= listing._id %>" class="listing-links">
      <div class="card index-card h-100 listing-card">
        <img src="<%= listing.image.url  %>" class="card-img-top index-img" alt="listing/image">
        <div class="card-body">
          <p class="card-text">
            <b> <%= listing.title  %>
            </b> <br>
            &#8377; <span class="listing-price" data-base-price="<%= listing.price %>"><%= listing.price.toLocaleString("en-IN") %></span> /night
            <i class="tax-info"> &nbsp; includes 18% gst</i>
          </p>
        </div>
      </div>
    </a>

    <% } %>
  </div>

</body>